ca-actions: <$action-sendmessage $message="rimir-cascade-palette-clear-context"/><$action-sendmessage $message="rimir-cascade-palette-pin-context" title=<<currentTiddler>>/><$action-sendmessage $message="rimir-cascade-palette-set-view" view="$:/plugins/rimir/worga/views/topics-for-context"/>
